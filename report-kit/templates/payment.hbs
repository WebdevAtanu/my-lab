<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">

    <style>
        body {
            font-family: Arial;
            padding: 30px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th,
        td {
            border: 1px solid #ddd;
            padding: 8px;
        }

        th {
            background: #f3f3f3;
        }

        h1 {
            color: #333;
        }
    </style>
</head>

<body>

    <h1>Payments</h1>

    <table>

        <thead>
            <tr>
                <th>Customer</th>
                <th>Amount</th>
                <th>Date</th>
            </tr>
        </thead>

        <tbody>

            {{#each payments}}

            <tr>
                <td>{{UserName}}</td>
                <td>{{PaidAmount}}</td>
                <td>{{PaymentDate}}</td>
            </tr>

            {{/each}}

        </tbody>

    </table>

    <h3>Total : {{currency total}}</h3>

</body>

</html>