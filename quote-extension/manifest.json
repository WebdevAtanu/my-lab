{
  "manifest_version": 3,
  "name": "Random Quote Generator",
  "description": "Simple Chrome Extension for testing",
  "version": "1.0",
  "permissions": ["activeTab", "storage", "scripting", "alarms"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Click Me",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon16.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "css": ["style.css"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon16.png",
    "48": "icons/icon16.png",
    "128": "icons/icon16.png"
  }
}
